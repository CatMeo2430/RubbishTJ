<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
  <appSettings>
    <!-- 监听地址，末尾须带 / -->
    <add key="ListenUrl" value="http://127.0.0.1:8765/" />
    <!-- TaiJi 登录（留空则尝试 CredentialStore 已存凭据） -->
    <add key="Account" value="" />
    <add key="Password" value="" />
    <add key="RememberLogin" value="true" />
  </appSettings>
</configuration>
